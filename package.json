{
  "name": "codecraft",
  "version": "0.1.0",
  "description": "An open-source AI coding agent with a beautiful terminal UI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "codecraft": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli/index.tsx",
    "build": "tsup",
    "start": "node dist/cli/index.js",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "cli",
    "terminal",
    "llm",
    "openai",
    "claude",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "dotenv": "^17.4.0",
    "globby": "^14.0.2",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "openai": "^4.67.1",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.11.1",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
